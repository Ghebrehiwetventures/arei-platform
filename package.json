{
  "name": "arei-platform",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "npm run dev --prefix arei-admin",
    "dev:kaza": "npm run dev --prefix kazaverde-web",
    "pipeline:cv": "npx ts-node --transpile-only core/preflightCv.ts && npm run ingest:cv && npm run report:cv",
    "ingest:cv": "DETAIL_ENRICH=1 DETAIL_ENRICH_LIMIT=50 npx ts-node --transpile-only core/ingestCv.ts",
    "report:cv": "npx ts-node --transpile-only core/reportCv.ts",
    "pipeline": "MARKET_ID=${MARKET_ID:?MARKET_ID required} npx ts-node --transpile-only core/preflightMarket.ts && npm run ingest && npm run report",
    "ingest": "MARKET_ID=${MARKET_ID:?MARKET_ID required} npx ts-node --transpile-only core/ingestMarket.ts",
    "report": "MARKET_ID=${MARKET_ID:?MARKET_ID required} npx ts-node --transpile-only core/reportMarket.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@supabase/supabase-js": "^2.91.0",
    "cheerio": "^1.0.0",
    "dotenv": "^17.2.3",
    "js-yaml": "^4.1.0",
    "openai": "^6.34.0",
    "pg": "^8.18.0",
    "puppeteer": "^24.36.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sanitize-html": "^2.17.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.16.0",
    "@types/sanitize-html": "^2.16.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
