{
  "name": "arei-platform",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "npm run dev --prefix arei-admin",
    "dev:kaza": "npm run dev --prefix kazaverde-web",
    "audit:vercel-links": "node scripts/audit-vercel-links.cjs",
    "verify:deploy:landing": "node scripts/verify-deploy-target.cjs landing",
    "verify:deploy:kazaverde": "node scripts/verify-deploy-target.cjs kazaverde",
    "deploy:landing": "node scripts/verify-deploy-target.cjs landing && npx vercel deploy --cwd web/prototypes --prod --yes",
    "deploy:kazaverde": "node scripts/verify-deploy-target.cjs kazaverde && npx vercel deploy --cwd . --prod --yes",
    "check:kazaverde-deploy": "node scripts/check-kazaverde-deploy.mjs",
    "pipeline:cv": "npx ts-node --transpile-only core/preflightCv.ts && npm run ingest:cv && npm run stale:cv && npm run kpi:cv && npm run regression:cv",
    "ingest:cv": "DETAIL_ENRICH=1 DETAIL_ENRICH_LIMIT=50 npx ts-node --transpile-only core/ingestCv.ts",
    "report:cv": "npx ts-node --transpile-only core/reportCv.ts",
    "stale:cv": "npx ts-node --transpile-only scripts/stale_cleanup_cv.ts",
    "kpi:cv": "npx ts-node --transpile-only scripts/cv_kpi_report.ts",
    "regression:cv": "npx ts-node --transpile-only scripts/cv_regression_check.ts",
    "weekly:cv": "npx ts-node --transpile-only scripts/cv_weekly_ops_summary.ts",
    "dedupe:cv:observe": "npx ts-node --transpile-only core/dedupeObserveCv.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.91.0",
    "cheerio": "^1.0.0",
    "dotenv": "^17.2.3",
    "image-size": "^2.0.2",
    "jimp": "^1.6.0",
    "js-yaml": "^4.1.0",
    "pg": "^8.18.0",
    "puppeteer": "^24.36.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sanitize-html": "^2.17.1",
    "tldts": "^7.0.27"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.16.0",
    "@types/sanitize-html": "^2.16.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
