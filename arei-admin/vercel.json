{
  "buildCommand": "npm run build",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- .",
  "outputDirectory": "dist",
  "framework": null,
  "crons": [
    { "path": "/api/social-listing-cron", "schedule": "* * * * *" },
    { "path": "/api/enrich-pending-cron", "schedule": "15 * * * *" }
  ],
  "functions": {
    "api/social-listing.js": { "maxDuration": 300 },
    "api/social-listing-cron.js": { "maxDuration": 300 },
    "api/generate-news-post-image.js": { "maxDuration": 60 },
    "api/enrich-pending-cron.js": { "maxDuration": 120 },
    "api/reenrich-market-news.js": { "maxDuration": 300 },
    "api/publish-news-post.js": { "maxDuration": 120 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/assets/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
  ]
}
