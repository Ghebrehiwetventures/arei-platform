# Template for the workspace-root .env file.
#
# kazaverde-web reads .env from the workspace root (see envDir in
# vite.config.ts), NOT from this directory. Copy this file to ../.env
# and fill in the values, or merge into the existing ../.env.
#
#   cp kazaverde-web/.env.example .env

# ── Supabase (frontend) ───────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── KazaVerde feed view ───────────────────────────────────────────────────
# Leave unset to use the SDK default (v1_feed_cv).
#   v1_feed_cv_dev              all rows incl. needs_review — local QA
#   v1_feed_cv                  published only — mirrors production
#   v1_feed_cv_curated_preview  raw curated preview
#VITE_AREI_FEED_VIEW=v1_feed_cv_dev
