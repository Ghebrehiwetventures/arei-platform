{
  "buildCommand": "cd ../packages/arei-sdk && npm install && npm run build && cd ../../kazaverde-web && npm install && npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/market", "destination": "/market/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/(.*)", "destination": "/blog/$1/index.html" },
    { "source": "/listing/tcv_ba753c539a1b", "destination": "/listing/tcv_ba753c539a1b/index.html" },
    { "source": "/listing/cv_gabetticasecapoverde:CV-TER379", "destination": "/listing/cv_gabetticasecapoverde:CV-TER379/index.html" },
    { "source": "/listing/ecv_4f9d29d41403", "destination": "/listing/ecv_4f9d29d41403/index.html" },
    { "source": "/listing/tcv_d8733fc16727", "destination": "/listing/tcv_d8733fc16727/index.html" },
    { "source": "/listing/tcv_04bb5217e68f", "destination": "/listing/tcv_04bb5217e68f/index.html" },
    { "source": "/listing/tcv_39e67cf7540e", "destination": "/listing/tcv_39e67cf7540e/index.html" },
    { "source": "/listing/tcv_26016a3d880d", "destination": "/listing/tcv_26016a3d880d/index.html" },
    { "source": "/listing/tcv_9fd89e02a045", "destination": "/listing/tcv_9fd89e02a045/index.html" },
    { "source": "/listing/tcv_a26cf7666960", "destination": "/listing/tcv_a26cf7666960/index.html" },
    { "source": "/listing/cv_gabetticasecapoverde:CV-AP387", "destination": "/listing/cv_gabetticasecapoverde:CV-AP387/index.html" },
    { "source": "/listing/cv_gabetticasecapoverde:CV-AP208", "destination": "/listing/cv_gabetticasecapoverde:CV-AP208/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/cookie-policy", "destination": "/cookie-policy/index.html" },
    { "source": "/(.*)", "destination": "/spa-fallback/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
